# Salin file ini ke .env dan isi nilai-nilainya
# Jangan commit .env ke git

# Database (dipakai backend)
DATABASE_URL=postgresql://user:password@host:5432/purrtein

# MQTT
EMQX_NODE_COOKIE=ganti_dengan_random_string

# MediaMTX
MEDIAMTX_PASS=ganti_dengan_password_kuat

# MJPEG ingest (ESP32 stream push -> ffmpeg -> mediamtx)
# Harus sama persis dengan STREAM_INGEST_TOKEN di firmware include/secrets.h
INGEST_TOKEN=ganti_dengan_random_string

# Backend
NODE_ENV=production
JWT_SECRET=ganti_dengan_random_string

# Domain
DOMAIN=purrduli.tech
